# ============================================
# GOOGLE CALENDAR
# Sigue la guía en docs/BOOKING_SETUP.md
# ============================================

# Obtén estas credenciales en: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Obtén el refresh token en: https://developers.google.com/oauthplayground
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# ID del calendario (usa "primary" para el calendario principal)
GOOGLE_CALENDAR_ID=primary

# ============================================
# RESEND (envío de emails)
# Crea cuenta en: https://resend.com
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email del propietario para recibir notificaciones de nuevas reservas
OWNER_EMAIL=tu@email.com

# ============================================
# ADMIN PANEL
# ============================================
# Contraseña para acceder a /admin
ADMIN_PASSWORD=tu_contraseña_segura

# Token de sesión (genera una cadena aleatoria larga, ej: openssl rand -hex 32)
ADMIN_TOKEN=genera-un-string-aleatorio-aqui-de-32-caracteres

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
