# ============================================
# GOOGLE CALENDAR
# Sigue la guía en docs/BOOKING_SETUP.md
# ============================================

# Obtén estas credenciales en: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Obtén el refresh token en: https://developers.google.com/oauthplayground
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# ID del calendario (usa "primary" para el calendario principal)
GOOGLE_CALENDAR_ID=primary

# ============================================
# RESEND (envío de emails)
# Crea cuenta en: https://resend.com
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email del propietario para recibir notificaciones de nuevas reservas
OWNER_EMAIL=tu@email.com

# ============================================
# ADMIN PANEL
# ============================================
# Contraseña para acceder a /admin
ADMIN_PASSWORD=tu_contraseña_segura

# Token de sesión (genera una cadena aleatoria larga, ej: openssl rand -hex 32)
ADMIN_TOKEN=genera-un-string-aleatorio-aqui-de-32-caracteres

# ============================================
# CRON SECRET (para VPS cron jobs externos)
# ============================================
# Genera un valor seguro con: openssl rand -hex 32
CRON_SECRET=genera-otro-string-aleatorio-de-64-caracteres-hex

# ============================================
# POSTGRES DATABASE (Producción Dokply)
# ============================================
PG_HOST=161.97.125.245
PG_PORT=5432
PG_DATABASE=lumicatechdb
PG_USER=Jose
PG_PASSWORD=xPR1wjfW31hFs6OdbaYm

# O usar connection string completa:
# DATABASE_URL=postgresql://Jose:xPR1wjfW31hFs6OdbaYm@161.97.125.245:5432/lumicatechdb

# ============================================
# MIGRACIONES AUTOMÁTICAS
# ============================================
# Controla si se ejecutan las migraciones al iniciar la app
# true = NO ejecutar migraciones (DB ya existe)
# false = SÍ ejecutar migraciones (DB nueva o recrear)
SKIP_MIGRATIONS=false

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
